{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Adyen Demo",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["ts-node", "index.ts"],
            "cwd": "${workspaceFolder}",
            "sourceMaps": true,
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "node_modules/**"]
        }
    ]
}
